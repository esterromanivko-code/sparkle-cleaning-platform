# ─── SERVER ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── SECURITY ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ─── STRIPE ────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
STRIPE_BG_CHECK_PRICE=3000          # $30.00 in cents
STRIPE_PRO_MONTHLY_PRICE=1800       # $18.00 in cents
STRIPE_PRO_ANNUAL_PRICE=18000       # $180.00 in cents
STRIPE_GUARANTEE_PRICE=1200         # $12.00 in cents
STRIPE_PRIORITY_PRICE=700           # $7.00 in cents

# ─── CHECKR (Background checks) ────────────────────
# Sign up at https://checkr.com → get API key from dashboard
CHECKR_API_KEY=your_checkr_api_key_here
CHECKR_PACKAGE=tasker_standard       # or pro_criminal, driver_pro etc.
CHECKR_WEBHOOK_SECRET=your_checkr_webhook_secret

# ─── STRIPE IDENTITY (ID Verification) ─────────────
# Already included in your Stripe account - just enable it
STRIPE_IDENTITY_ENABLED=true

# ─── EMAIL (Nodemailer) ─────────────────────────────
# Use Gmail, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Sparkle <hello@sparkle.com>

# ─── CAPTCHA (Cloudflare Turnstile) ────────────────
# Setup: dash.cloudflare.com → Turnstile → Add Site
# Choose "Invisible" widget type
TURNSTILE_SECRET_KEY=TURNSTILE_SECRET_KEY_HERE
TURNSTILE_SITE_KEY=TURNSTILE_SITE_KEY_HERE       # used in your frontend HTML

# ─── FRONTEND ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── PLATFORM FEES ─────────────────────────────────
PLATFORM_FEE_PERCENT=8              # 8% from regular clients (covers Stripe ~3% + real margin)
BUSINESS_FEE_PERCENT=10            # 10% from business/property manager accounts
TIP_FEE_PERCENT=1.5                # 1.5% on tips
INSTANT_CASHOUT_FEE=10.00          # $10 flat fee for instant payout (minutes)
STANDARD_CASHOUT_FEE=0             # Free for weekly scheduled payouts
BG_CHECK_PRICE=30.00               # Cleaner pays $30 (covers costs + ~$10.50 margin) ($40 - $19.50 costs = ~$20.50 profit per check)
